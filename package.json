{
  "name": "whatsapp-desktop",
  "version": "1.0.0",
  "description": "WhatsApp Desktop Client with Native Features",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"bun run dev:vite\" \"bun run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && tsc -p tsconfig.node.json && electron . --dev",
    "build": "bun run build:main && bun run build:renderer",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "package": "bun run build && electron-builder --linux deb rpm",
    "package:deb": "bun run build && electron-builder --linux deb",
    "package:rpm": "bun run build && electron-builder --linux rpm",
    "start": "electron ."
  },
  "keywords": [
    "whatsapp",
    "electron",
    "desktop"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/dewald-els/whatsapp-desktop",
  "type": "commonjs",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "auto-launch": "^5.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dbus-next": "^0.10.2",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  }
}
